# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ──────────────────────────────────────────────────────────────
# "faiss" (local, no key needed) or "pinecone" (cloud)
VECTOR_STORE_BACKEND=faiss

# Pinecone – only needed when VECTOR_STORE_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=finsight-sec-filings

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
SEC_EDGAR_USER_AGENT=FinSight research@finsight.example.com
SEC_MAX_FILINGS=5

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_API_URL=http://localhost:8000

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=finsight-evaluation
